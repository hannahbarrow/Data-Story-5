gender <- gsub("MAN", " Male", cd$gender)
gender <- gsub("female", "Female", gender)
gender <- gsub("woman", "Female", gender)
gender <- gsub(" ", "", gender)
cd$gender <- gender
cd %>% kable
cd$date <- gsub("/", "-", cd$date)
cd$date <- gsub("March", "03", cd$date)
cd$date <- gsub("march", "03", cd$date)
cd$date <- gsub(" ", "-", cd$date)
cd$date <- gsub(",", "", cd$date)
cd$date <- gsub("--", "", cd$date)
cd <- cd %>% mutate(date = ifelse(date == "3-16", "3-16-2026", date))
date_split <- str_split(cd$date, "-")
m <- sapply(date_split, "[[", 1)
d <- sapply(date_split, "[[", 2)
y <- sapply(date_split, "[[", 3)
mm <- str_pad(m, width = 2, side = "left", pad = "0")
dd <- str_pad(d, width = 2, side = "left", pad = "0")
yy <- str_pad(y, width = 3, side = "left", pad = "0")
yyyy <- str_pad(yy, width = 4, side = "left", pad = "2")
cd$date <- paste0(mm, "-", dd, "-", yyyy)
cd <- cd %>%
mutate(time = ifelse(time == "1:41", "1:41 pm", time)) %>%
mutate(time = ifelse(time == "8:11", "8:11 am", time)) %>%
mutate(time = ifelse(time == "9:45", "9:45 am", time)) %>%
mutate(time = ifelse(time == "12:17", "12:17 pm", time))
cd$time <- gsub("2pm", "2 pm", cd$time)
time_split <- str_split(cd$time, ":| ")
h <- sapply(time_split, "[[", 1)
min <- sapply(time_split, "[[", 2)
ap <- sapply(time_split, "[[", 3)
hh <- str_pad(h, width = 2, side = "left", pad = "0")
apm <- gsub("PM", "pm", ap)
apm <- gsub("p.m.", "pm", apm)
apm <- gsub("AM", "am", apm)
cd %>% kable
library(ggplot2)
ggplot(cd,
aes(x = date,
y = time,
color = gender))
ggplot(cd,
aes(x = date,
y = time,
color = gender))+
geom_path()
ggplot(cd,
aes(x = date,
y = time,
color = gender))+
geom_point()
ggplot(cd,
aes(x = date,
y = time,
color = gender))+
geom_point()+
theme_bw()
